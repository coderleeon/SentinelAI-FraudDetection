# ──────────────────────────────────────────────────────────────────────────────
# AI Fraud Detection System — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Model Configuration
PRIMARY_MODEL=xgboost
MODEL_DIR=models

# Dashboard Configuration
DASHBOARD_PORT=8501
API_URL=http://localhost:8000

# Alert Configuration (optional)
ALERT_EMAIL=
ALERT_EMAIL_TO=
ALERT_EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Logging
LOG_LEVEL=INFO
